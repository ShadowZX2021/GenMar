<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>@ViewBag.Title</title>

    @Styles.Render("~/Content/css")
    @Scripts.Render("~/bundles/modernizr")
</head>

<body>

    @if (Session["Usuario"] != null)
    {
        var user = Session["Usuario"] as ControlGastosMVC.Models.Usuarios;

        <div class="sidebar">
            <h4>Control Gastos</h4>

            @Html.ActionLink("Inicio", "Index", "Home")

            @if (user.IdNivelUsuario == 1) // 🔴 ADMIN
            {
                @Html.ActionLink("Usuarios", "Index", "Usuarios")
                @Html.ActionLink("Datos Personales", "Index", "DatosPersonales")
            }

            @Html.ActionLink("Gastos", "Index", "Gastos")

            <hr />

            @Html.ActionLink("Cerrar sesión", "Logout", "Account")
        </div>
    }

    <!-- CONTENIDO -->
    <div class="main-content">
        @RenderBody()

        <hr />
        <footer class="footer">
            <p>© @DateTime.Now.Year - Control de Gastos - Andres Ferrer Servin</p>
        </footer>
    </div>

    <!-- 🔥 ESTO SOLUCIONA TU ERROR -->
    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/bootstrap")

    @RenderSection("Scripts", required: false)

</body>
</html>