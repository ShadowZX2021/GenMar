@model ControlGastosMVC.Models.Usuarios

@{
    ViewBag.Title = "Crear Usuario";
}

<div class="card shadow p-4" style="max-width:700px; margin:auto; border-radius:15px;">

    <h3 class="text-center mb-4" style="color:#8B0000;">
        👤 Nuevo Usuario
    </h3>

    @using (Html.BeginForm())
    {
        @Html.AntiForgeryToken()

        @Html.ValidationSummary(true, "", new { @class = "alert alert-danger" })

        <!-- DATOS PERSONALES -->
        <div class="mb-3">
            <label>Persona</label>
            @Html.DropDownList("IdDatos", null, "Seleccione...", new { @class = "form-control" })
        </div>

        <!-- ROL -->
        <div class="mb-3">
            <label>Rol</label>
            @Html.DropDownList("IdNivelUsuario", null, "Seleccione...", new { @class = "form-control" })
        </div>

        <!-- NOMBRE -->
        <div class="mb-3">
            <label>Nombre</label>
            @Html.TextBoxFor(m => m.Nombre, new { @class = "form-control", placeholder = "Nombre del usuario" })
        </div>

        <!-- EMAIL -->
        <div class="mb-3">
            <label>Email</label>
            @Html.TextBoxFor(m => m.Email, new { @class = "form-control", placeholder = "correo@ejemplo.com", type = "email" })
        </div>

        <!-- PASSWORD -->
        <div class="mb-3">
            <label>Contraseña</label>
            @Html.PasswordFor(m => m.Password, new { @class = "form-control", placeholder = "********" })
        </div>

        <!-- FECHA -->
        <div class="mb-3">
            <label>Fecha Registro</label>
            @Html.TextBoxFor(m => m.FechaRegistro, "{0:yyyy-MM-dd}",
                new { @class = "form-control", type = "date" })
        </div>

        <!-- ESTATUS -->
        <div class="mb-3">
            <label>Estatus</label>
            @Html.DropDownListFor(m => m.IdEstatus,
                new List<SelectListItem>
                {
                    new SelectListItem { Text = "Activo", Value = "1" },
                    new SelectListItem { Text = "Inactivo", Value = "0" }
                },
                "Seleccione...",
                new { @class = "form-control" })
        </div>

        <!-- BOTONES -->
        <div class="d-flex justify-content-between mt-4">
            @Html.ActionLink("⬅ Volver", "Index", null, new { @class = "btn btn-secondary" })

            <button type="submit" class="btn btn-danger">
                💾 Guardar
            </button>
        </div>
    }
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}