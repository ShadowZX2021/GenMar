@model ControlGastosMVC.Models.DatosPersonales

@{
    ViewBag.Title = "Crear Datos Personales";
}

<div class="card shadow p-4" style="max-width:700px; margin:auto; border-radius:15px;">

    <h3 class="text-center mb-4" style="color:#8B0000;">
        👤 Nuevo Registro
    </h3>

    @using (Html.BeginForm())
    {
        @Html.AntiForgeryToken()
        @Html.ValidationSummary(true, "", new { @class = "alert alert-danger" })

        
        <div class="mb-3">
            <label>Nombre</label>
            @Html.TextBoxFor(m => m.Nombre, new { @class = "form-control", placeholder = "Nombre" })
        </div>

        
        <div class="mb-3">
            <label>Apellido Paterno</label>
            @Html.TextBoxFor(m => m.ApPaterno, new { @class = "form-control", placeholder = "Apellido Paterno" })
        </div>

       
        <div class="mb-3">
            <label>Apellido Materno</label>
            @Html.TextBoxFor(m => m.ApMaterno, new { @class = "form-control", placeholder = "Apellido Materno" })
        </div>

        
        <div class="mb-3">
            <label>Teléfono</label>
            @Html.TextBoxFor(m => m.Telefono, new { @class = "form-control", placeholder = "Teléfono" })
        </div>

       
        <div class="mb-3">
            <label>Dirección</label>
            @Html.TextBoxFor(m => m.Direccion, new { @class = "form-control", placeholder = "Dirección" })
        </div>

       
        <div class="mb-3">
            <label>Sueldo Base</label>
            @Html.TextBoxFor(m => m.SueldoBase, new { @class = "form-control", placeholder = "Sueldo Base", type = "number", step = "0.01" })
        </div>

        
        <div class="mb-3">
            <label>Tipo de Sueldo</label>
            @Html.DropDownList("IdTipoSueldo", null, "Seleccione...", new { @class = "form-control" })
        </div>

        
        <div class="mb-3">
            <label>Estatus</label>
            @Html.DropDownListFor(m => m.IdEstatus,
                new List<SelectListItem>
                {
                    new SelectListItem { Text = "Activo", Value = "1" },
                    new SelectListItem { Text = "Inactivo", Value = "0" }
                },
                "Seleccione...",
                new { @class = "form-control" })
        </div>

        <div class="d-flex justify-content-between mt-4">
            @Html.ActionLink("⬅ Volver", "Index", null, new { @class = "btn btn-secondary" })
            <button type="submit" class="btn btn-danger">
                💾 Guardar
            </button>
        </div>
    } 
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}