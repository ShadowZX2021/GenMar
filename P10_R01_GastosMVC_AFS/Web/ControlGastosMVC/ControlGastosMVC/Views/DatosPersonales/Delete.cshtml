@model ControlGastosMVC.Models.DatosPersonales

@{
    ViewBag.Title = "Eliminar Datos Personales";
}

<h2 class="mb-3">🗑️ Eliminar Registro</h2>

<h4>¿Estás seguro de que quieres eliminar este registro?</h4>

<div class="card mb-4" style="max-width:600px;">
    <div class="card-body">
        <h5 class="card-title">@Model.Nombre @Model.ApPaterno @Model.ApMaterno</h5>

        <p class="card-text"><strong>Teléfono:</strong> @Model.Telefono</p>
        <p class="card-text"><strong>Dirección:</strong> @Model.Direccion</p>
        <p class="card-text"><strong>Sueldo Base:</strong> @(Model.SueldoBase.HasValue ? String.Format("{0:C}", Model.SueldoBase.Value) : "-")</p>

        <p class="card-text">
            <strong>Estatus:</strong>
            @if (Model.IdEstatus == 1)
            {
                <span class="badge bg-success">Activo</span>
            }
            else
            {
                <span class="badge bg-secondary">Inactivo</span>
            }
        </p>

        <p class="card-text">
            <strong>Tipo de Sueldo:</strong> @Model.TipoSueldo.Descripcion
        </p>
    </div>
</div>

@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()

    <div class="mb-3">
        <input type="submit" value="🗑️ Eliminar" class="btn btn-danger" />
        @Html.ActionLink("⬅️ Volver al listado", "Index", null, new { @class = "btn btn-secondary" })
    </div>
} 