<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>@ViewBag.Title - Sistema</title>

    <link href="https://maxcdn.bootstrapcdn.com/bootstrap/3.4.1/css/bootstrap.min.css" rel="stylesheet" />
    <link href="~/Content/Site.css" rel="stylesheet" />
</head>
<body>

    <!-- 🔐 NAVBAR SOLO SI HAY SESIÓN -->
    @if (Session["Usuario"] != null)
    {
        <nav class="navbar navbar-inverse">
            <div class="container">

                <div class="navbar-header">
                    <button type="button" class="navbar-toggle" data-toggle="collapse" data-target=".navbar-collapse">
                        <span class="icon-bar"></span>
                        <span class="icon-bar"></span>
                        <span class="icon-bar"></span>
                    </button>

                    @Html.ActionLink("Sistema de Transportes", "Index", "Home", null, new { @class = "navbar-brand" })
                </div>

                <div class="collapse navbar-collapse">
                    <ul class="nav navbar-nav navbar-right">
                        <li>@Html.ActionLink("Inicio", "Index", "Home")</li>
                        <li>@Html.ActionLink("Camiones", "Index", "Camiones")</li>
                        <li>@Html.ActionLink("Choferes", "Index", "Chofers")</li>
                        <li>@Html.ActionLink("Rutas", "Index", "Rutas")</li>

                        <!-- 👤 USUARIO -->
                        <li><a>Hola, @Session["Usuario"]</a></li>

                        <!-- 🚪 LOGOUT -->
                        <li>@Html.ActionLink("Salir", "Logout", "Account")</li>
                    </ul>
                </div>

            </div>
        </nav>
    }

    <!-- 🎞️ CARRUSEL SOLO SI HAY SESIÓN -->
    @if (Session["Usuario"] != null)
    {
        <div class="container" style="margin-top:15px;">

            <div id="carouselExample" class="carousel slide" data-ride="carousel" data-interval="2000">

                <ol class="carousel-indicators">
                    <li data-target="#carouselExample" data-slide-to="0" class="active"></li>
                    <li data-target="#carouselExample" data-slide-to="1"></li>
                    <li data-target="#carouselExample" data-slide-to="2"></li>
                </ol>

                <div class="carousel-inner">

                    <div class="item active">
                        <img src="https://picsum.photos/1200/300?random=1" />
                    </div>

                    <div class="item">
                        <img src="https://picsum.photos/1200/300?random=2" />
                    </div>

                    <div class="item">
                        <img src="https://picsum.photos/1200/300?random=3" />
                    </div>

                </div>

                <a class="left carousel-control" href="#carouselExample" data-slide="prev">
                    <span class="glyphicon glyphicon-chevron-left"></span>
                </a>

                <a class="right carousel-control" href="#carouselExample" data-slide="next">
                    <span class="glyphicon glyphicon-chevron-right"></span>
                </a>

            </div>

        </div>
    }

    <!-- 📄 CONTENIDO -->
    <div class="container body-content content-box">
        @RenderBody()
        <hr />
        <footer class="text-center">
            <p>&copy; @DateTime.Now.Year - Sistema de Transportes - By Andres Ferrer Servin</p>
        </footer>
    </div>

    <!-- SCRIPTS -->
    <script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
    <script src="https://maxcdn.bootstrapcdn.com/bootstrap/3.4.1/js/bootstrap.min.js"></script>

</body>
</html>